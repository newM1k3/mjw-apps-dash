# ImmersiveKit Dashboard (mjw-apps-dash) — environment variables
# Copy this file to `.env` and fill in real values. All vars are build-time
# (Vite inlines anything prefixed VITE_ into the client bundle — never put
# secrets here).

# ── Platform ────────────────────────────────────────────────────────────────
# PocketBase backend base URL
VITE_POCKETBASE_URL=https://immersive-kit.pockethost.io
# Platform gateway (serverless) base URL
VITE_PLATFORM_GATEWAY_URL=
# Stripe upgrade / checkout link used by the subscription gate
VITE_STRIPE_UPGRADE_URL=

# ── Onboarding ────────────────────────────────────────────────────────────────
# Venue Intelligence Wizard (standalone onboarding app). Falls back to the
# deployed URL if unset.
VITE_VENUE_INTELLIGENCE_WIZARD_URL=https://venue-intel-wizard.netlify.app

# ── Feature flags ─────────────────────────────────────────────────────────────
# When not "false", all signed-in users can launch every tool regardless of
# tier (beta all-access). Set to "false" to enforce the per-tool requiredTier.
VITE_ENABLE_BETA_ALL_ACCESS=true

# ── Tool URLs (one per tool in src/data/apps.ts) ──────────────────────────────
# Design suite
VITE_LOCK_MAPPING_STUDIO_URL=
VITE_PUZZLE_DEPENDENCY_AUDITOR_URL=
VITE_ROOM_LAYOUT_RISK_MAPPER_URL=
VITE_PUZZLE_FLOW_VISUALIZER_URL=
VITE_PRODUCTION_BIBLE_BUILDER_URL=
VITE_AI_ESCAPE_ROOM_GENERATOR_URL=

# Operations suite
VITE_ROOMREADY_OPS_URL=
VITE_GM_SCRIPT_LIBRARY_URL=
VITE_PARTY_PROFIT_PLANNER_URL=

# Marketing suite
VITE_MARKETING_PLAYBOOK_GENERATOR_URL=
VITE_MARKETING_AUDIT_TOOL_URL=
VITE_REVIEW_SCORECARD_ANALYZER_URL=
VITE_SEASONAL_CAMPAIGN_BUILDER_URL=
VITE_SCHEMA_MARKUP_GENERATOR_URL=
VITE_CONTENT_OS_MASTERMIND_URL=
